<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AddExpenseActivity">

    <!-- Top Logo -->
    <ImageView
        android:id="@+id/topLogo"
        android:layout_width="110dp"
        android:layout_height="90dp"
        android:src="@drawable/aimnestlogo2"
        android:scaleType="fitCenter"
        android:contentDescription="AimNest Logo"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Title Row with Back Button -->
    <LinearLayout
        android:id="@+id/titleRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="16dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/topLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Back Button Icon on Left -->
        <ImageView
            android:id="@+id/backButton"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/back"
            android:scaleType="fitCenter"
            android:contentDescription="Back" />

        <!-- Spacer to push title to center -->
        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Add Expense Title (Centered) -->
        <TextView
            android:id="@+id/addExpenseTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Expense"
            android:textSize="20sp"
            android:textColor="#0B0F3F"
            android:textStyle="bold" />

        <!-- Spacer to balance the layout -->
        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- Scrollable Content Area -->
    <ScrollView
        android:id="@+id/contentScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/titleRow"
        app:layout_constraintBottom_toTopOf="@id/footerPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- Form Container CardView -->
            <androidx.cardview.widget.CardView
                android:id="@+id/formCardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#E3F2FD">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Expense Name Field -->
                    <TextView
                        android:id="@+id/expenseNameLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Expense Name"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/expenseNameInput"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/rounded_input_background"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:hint="Enter expense name"
                        android:textSize="14sp"
                        android:layout_marginBottom="20dp"
                        android:inputType="text" />

                    <!-- Amount Field -->
                    <TextView
                        android:id="@+id/amountLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Amount"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:background="@drawable/rounded_input_background"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:layout_marginBottom="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rs "
                            android:textSize="14sp"
                            android:textColor="#333333"
                            android:layout_marginEnd="8dp" />

                        <EditText
                            android:id="@+id/amountInput"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="0.00"
                            android:textSize="14sp"
                            android:inputType="numberDecimal" />

                    </LinearLayout>

                    <!-- Category Field -->
                    <TextView
                        android:id="@+id/categoryLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Category"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:background="@drawable/rounded_input_background"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:layout_marginBottom="20dp">

                        <Spinner
                            android:id="@+id/categorySpinner"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@null"
                            android:spinnerMode="dropdown" />

                    </LinearLayout>

                    <!-- Mandatory Toggle Field -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">

                        <TextView
                            android:id="@+id/mandatoryLabel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Mandatory"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#333333" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/mandatorySwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:switchPadding="8dp" />

                    </LinearLayout>

                    <!-- Expense Date Field -->
                    <TextView
                        android:id="@+id/dateLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Expense Date"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:orientation="horizontal"
                        android:background="@drawable/rounded_input_background"
                        android:gravity="center_vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:layout_marginBottom="20dp">

                        <TextView
                            android:id="@+id/dateInputText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="04/01/2026"
                            android:textSize="14sp"
                            android:textColor="#333333" />

                        <ImageView
                            android:id="@+id/calendarIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/calendar"
                            android:contentDescription="Calendar"
                            android:scaleType="fitCenter" />

                    </LinearLayout>

                    <!-- Save Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/saveExpenseButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Save Expense"
                        android:textColor="@android:color/white"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        app:backgroundTint="#1976D2"
                        app:cornerRadius="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/cancelExpenseButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:text="Cancel"
                        android:textColor="#555555"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        app:backgroundTint="#F2F2F2"
                        app:cornerRadius="12dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

    <!-- Footer UI Panel fixed at bottom -->
    <LinearLayout
        android:id="@+id/footerPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@android:color/white"
        android:elevation="8dp"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/menuItemManageIncome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="8dp">

            <ImageView
                android:id="@+id/iconManageIncome"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/manageincome"
                android:scaleType="fitCenter"
                android:contentDescription="Manage Income"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/labelManageIncome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage&#10;Income"
                android:textSize="12sp"
                android:textColor="#333333"
                android:textAlignment="center"
                android:lines="2" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/menuItemManageExpenses"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="8dp"
            android:paddingVertical="8dp"
            android:background="#E3F2FD"
            android:backgroundTint="#E3F2FD">

            <ImageView
                android:id="@+id/iconManageExpenses"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/manageexpenses"
                android:scaleType="fitCenter"
                android:contentDescription="Manage Expenses"
                android:layout_marginBottom="8dp"
                android:tint="#1976D2" />

            <TextView
                android:id="@+id/labelManageExpenses"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage&#10;Expenses"
                android:textSize="12sp"
                android:textColor="#1976D2"
                android:textAlignment="center"
                android:lines="2"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/menuItemManageTarget"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="8dp">

            <ImageView
                android:id="@+id/iconManageTarget"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/managetargets"
                android:scaleType="fitCenter"
                android:contentDescription="Manage Target"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/labelManageTarget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage&#10;Target"
                android:textSize="12sp"
                android:textColor="#333333"
                android:textAlignment="center"
                android:lines="2" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/menuItemViewAnalysis"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="8dp">

            <ImageView
                android:id="@+id/iconViewAnalysis"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/viewanalysis"
                android:scaleType="fitCenter"
                android:contentDescription="View Analysis"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/labelViewAnalysis"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View&#10;Analysis"
                android:textSize="12sp"
                android:textColor="#333333"
                android:textAlignment="center"
                android:lines="2" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>