<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ExpensesListActivity">

    <!-- Top Logo -->
    <ImageView
        android:id="@+id/topLogo"
        android:layout_width="110dp"
        android:layout_height="90dp"
        android:src="@drawable/aimnestlogo2"
        android:scaleType="fitCenter"
        android:contentDescription="AimNest Logo"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Title Row with Back Button -->
    <LinearLayout
        android:id="@+id/titleRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="16dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/topLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Back Button Icon on Left -->
        <ImageView
            android:id="@+id/backButton"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/back"
            android:scaleType="fitCenter"
            android:contentDescription="Back" />

        <!-- Spacer to push title to center -->
        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Expense List Title (Centered) -->

        <!-- Spacer to balance the layout -->

        <TextView
            android:id="@+id/expenseListTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Expense List"
            android:textColor="#0B0F3F"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- Scrollable Content Area -->
    <ScrollView
        android:id="@+id/contentScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/titleRow"
        app:layout_constraintBottom_toTopOf="@id/footerPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- Search Bar -->
            <androidx.cardview.widget.CardView
                android:id="@+id/searchCardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp">

                    <ImageView
                        android:id="@+id/searchIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/searchicon"
                        android:contentDescription="Search Icon"
                        android:layout_marginEnd="12dp" />

                    <EditText
                        android:id="@+id/searchEditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Search"
                        android:background="@null"
                        android:textSize="14sp"
                        android:inputType="text" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Category Filter Chips -->
            <HorizontalScrollView
                android:id="@+id/categoryScrollView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/chipAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="All"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:background="#E3F2FD"
                        android:textColor="#1976D2"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/chipRent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rent"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:background="#FFEBEE"
                        android:textColor="#D32F2F"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/chipUtilities"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Utilities"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:background="#FFF3E0"
                        android:textColor="#FF9800"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/chipFood"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Food"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:background="#E8F5E9"
                        android:textColor="#4CAF50"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/chipTransport"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Transport"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:background="#E1F5FE"
                        android:textColor="#0288D1"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/chipLoan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loan"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:background="#F3E5F5"
                        android:textColor="#9C27B0"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/chipGroceries"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Groceries"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:background="#E8F5E9"
                        android:textColor="#4CAF50"
                        android:textSize="12sp"
                        android:layout_marginStart="8dp" />

                    <TextView
                        android:id="@+id/chipEntertainment"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Entertainment"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:background="#EDE7F6"
                        android:textColor="#673AB7"
                        android:textSize="12sp"
                        android:layout_marginStart="8dp" />

                    <TextView
                        android:id="@+id/chipMedical"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Medical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:background="#FCE4EC"
                        android:textColor="#C2185B"
                        android:textSize="12sp"
                        android:layout_marginStart="8dp" />

                    <TextView
                        android:id="@+id/chipEducation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Education"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:background="#E0F7FA"
                        android:textColor="#00838F"
                        android:textSize="12sp"
                        android:layout_marginStart="8dp" />

                    <TextView
                        android:id="@+id/chipOther"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Other"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:background="#ECEFF1"
                        android:textColor="#455A64"
                        android:textSize="12sp"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

            </HorizontalScrollView>

            <!-- Dynamic Expenses Container -->
            <LinearLayout
                android:id="@+id/expensesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="80dp" />

        </LinearLayout>

    </ScrollView>

    <!-- Floating Add Expense Button -->
    <androidx.cardview.widget.CardView
        android:id="@+id/fabAddExpense"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        android:backgroundTint="#1976D2"
        android:layout_margin="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/footerPanel">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="20dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="#1976D2">

            <ImageView
                android:id="@+id/addButtonIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/plus"
                android:scaleType="fitCenter"

                android:contentDescription="Add Icon"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/addButtonText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add Expense"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Footer UI Panel fixed at bottom -->
    <LinearLayout
        android:id="@+id/footerPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@android:color/white"
        android:elevation="8dp"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/menuItemManageIncome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="8dp">

            <ImageView
                android:id="@+id/iconManageIncome"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/manageincome"
                android:scaleType="fitCenter"
                android:contentDescription="Manage Income"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/labelManageIncome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage&#10;Income"
                android:textSize="12sp"
                android:textColor="#333333"
                android:textAlignment="center"
                android:lines="2" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/menuItemManageExpenses"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="8dp"
            android:paddingVertical="8dp"
            android:background="#E3F2FD"
            android:backgroundTint="#E3F2FD">

            <ImageView
                android:id="@+id/iconManageExpenses"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/manageexpenses"
                android:scaleType="fitCenter"
                android:contentDescription="Manage Expenses"
                android:layout_marginBottom="8dp"
                android:tint="#1976D2" />

            <TextView
                android:id="@+id/labelManageExpenses"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage&#10;Expenses"
                android:textSize="12sp"
                android:textColor="#1976D2"
                android:textAlignment="center"
                android:lines="2"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/menuItemManageTarget"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="8dp">

            <ImageView
                android:id="@+id/iconManageTarget"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/managetargets"
                android:scaleType="fitCenter"
                android:contentDescription="Manage Target"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/labelManageTarget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage&#10;Target"
                android:textSize="12sp"
                android:textColor="#333333"
                android:textAlignment="center"
                android:lines="2" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/menuItemViewAnalysis"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="8dp">

            <ImageView
                android:id="@+id/iconViewAnalysis"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/viewanalysis"
                android:scaleType="fitCenter"
                android:contentDescription="View Analysis"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/labelViewAnalysis"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View&#10;Analysis"
                android:textSize="12sp"
                android:textColor="#333333"
                android:textAlignment="center"
                android:lines="2" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>