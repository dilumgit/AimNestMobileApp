<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".target_details">

    <!-- Top Logo -->
    <ImageView
        android:id="@+id/topLogo"
        android:layout_width="110dp"
        android:layout_height="90dp"
        android:src="@drawable/aimnestlogo2"
        android:scaleType="fitCenter"
        android:contentDescription="@string/app_name"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Title Row with Back Button -->
    <LinearLayout
        android:id="@+id/titleRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="16dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/topLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/backButton"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/back"
            android:scaleType="fitCenter"
            android:contentDescription="@string/app_name" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/targetDetailsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Target Details"
            android:textSize="20sp"
            android:textColor="#0B0F3F"
            android:textStyle="bold" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- Scrollable Content Area -->
    <ScrollView
        android:id="@+id/contentScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/titleRow"
        app:layout_constraintBottom_toTopOf="@id/footerPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:baselineAligned="false">

            <!-- Main Details Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/detailsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@android:color/white"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Header Row with Icon and Title -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">

                        <TextView
                            android:id="@+id/targetNameValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Emergency Fund"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#333333" />

                    </LinearLayout>

                    <!-- Detail Row 1: Total Target -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Total Target (Rs)"
                            android:textColor="#666666"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/totalTargetValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#333333"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Divider 1 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginBottom="12dp" />

                    <!-- Detail Row 2: Saved So Far -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Saved (Rs)"
                            android:textColor="#666666"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/savedValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#333333"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Divider 2 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginBottom="12dp" />

                    <!-- Detail Row 3: Remaining -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Remaining (Rs)"
                            android:textColor="#666666"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/remainingValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#333333"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Divider 3 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginBottom="12dp" />

                    <!-- Detail Row 4: Required Monthly -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Required Monthly (Rs)"
                            android:textColor="#666666"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/requiredMonthlyValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#333333"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Divider 4 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginBottom="12dp" />

                    <!-- Detail Row 5: Deadline -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Target Deadline"
                            android:textSize="14sp"
                            android:textColor="#666666" />

                        <TextView
                            android:id="@+id/deadlineValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="#333333"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Divider 5 -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginBottom="12dp" />

                    <!-- Detail Row 6: Priority -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="20dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Priority"
                            android:textSize="14sp"
                            android:textColor="#666666" />

                        <TextView
                            android:id="@+id/priorityValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="#1976D2"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Added missing target set date row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Target Set Date"
                            android:textColor="#666666"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/targetSetDateValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textColor="#333333"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="20dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Required Months"
                            android:textSize="14sp"
                            android:textColor="#666666" />

                        <TextView
                            android:id="@+id/requiredMonthsValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="#333333"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Progress Bar Section -->

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Edit Target Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/editTargetButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Edit Target"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="16sp"
                app:backgroundTint="#1976D2"
                app:cornerRadius="12dp"
                android:layout_marginBottom="16dp"
                android:baselineAligned="false" />

            <!-- Delete Target Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/deleteTargetButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Delete Target"
                android:textColor="#D32F2F"
                android:textStyle="bold"
                android:textSize="16sp"
                app:backgroundTint="#F5F5F5"
                app:cornerRadius="12dp" />

        </LinearLayout>

    </ScrollView>

    <!-- Footer UI Panel -->
    <LinearLayout
        android:id="@+id/footerPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@android:color/white"
        android:elevation="8dp"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/menuItemManageIncome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="8dp">

            <ImageView
                android:id="@+id/iconManageIncome"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/manageincome"
                android:scaleType="fitCenter"
                android:contentDescription="@string/app_name"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/labelManageIncome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage Income"
                android:textSize="12sp"
                android:textColor="#333333"
                android:textAlignment="center"
                android:lines="2" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/menuItemManageExpenses"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="8dp">

            <ImageView
                android:id="@+id/iconManageExpenses"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/manageexpenses"
                android:scaleType="fitCenter"
                android:contentDescription="@string/app_name"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/labelManageExpenses"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage Expenses"
                android:textSize="12sp"
                android:textColor="#333333"
                android:textAlignment="center"
                android:lines="2" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/menuItemManageTarget"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="8dp"
            android:paddingVertical="8dp"
            android:background="#E3F2FD">

            <ImageView
                android:id="@+id/iconManageTarget"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/managetargets"
                android:scaleType="fitCenter"
                android:contentDescription="@string/app_name"
                android:layout_marginBottom="8dp"
                app:tint="#1976D2" />

            <TextView
                android:id="@+id/labelManageTarget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage Target"
                android:textSize="12sp"
                android:textColor="#1976D2"
                android:textAlignment="center"
                android:lines="2"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/menuItemViewAnalysis"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="8dp">

            <ImageView
                android:id="@+id/iconViewAnalysis"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/viewanalysis"
                android:scaleType="fitCenter"
                android:contentDescription="@string/app_name"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/labelViewAnalysis"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View Analysis"
                android:textSize="12sp"
                android:textColor="#333333"
                android:textAlignment="center"
                android:lines="2" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

