<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Dashboard">

    <!-- Top Header Row with Menu and Logo -->
    <LinearLayout
        android:id="@+id/topHeaderRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@android:color/white"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- First Row: Menu Icon and Logo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Larger touch target for Menu Icon -->
            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:foregroundGravity="center"
                android:clickable="true"
                android:focusable="true"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/menuIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/menu"
                    android:scaleType="fitCenter"
                    android:contentDescription="Menu" />
            </FrameLayout>

            <!-- Spacer to center the logo -->
            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="0.85" />

            <!-- AimNest Logo in the Middle -->
            <ImageView
                android:id="@+id/headerLogo"
                android:layout_width="180dp"
                android:layout_height="150dp"
                android:src="@drawable/aimnestlogo2"
                android:scaleType="fitCenter"
                android:contentDescription="AimNest Logo" />

            <!-- Spacer to balance the layout -->
            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1.15" />

        </LinearLayout>

        <!-- Second Row: Greeting Text, Hi Icon, and Profile Picture -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginEnd="16dp">

            <!-- Greeting TextView -->
            <TextView
                android:id="@+id/greetingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Good Morning, Kavindu"
                android:textSize="22sp"
                android:textColor="#0B0F3F"
                android:textStyle="bold"
                android:gravity="center" />

            <!-- Hi Icon between greeting and profile picture -->
            <ImageView
                android:id="@+id/hiIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/hiicon"
                android:scaleType="fitCenter"
                android:contentDescription="Hi Icon"
                android:layout_marginStart="8dp" />

            <!-- Profile Picture on Right Side of Hi Icon with more spacing -->
            <androidx.cardview.widget.CardView
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="12dp"
                app:cardCornerRadius="25dp"
                app:cardElevation="0dp"
                app:cardUseCompatPadding="false"
                app:cardPreventCornerOverlap="true">

                <ImageView
                    android:id="@+id/profilePicture"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/profilepic"
                    android:scaleType="centerCrop"
                    android:contentDescription="Profile Picture" />

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <!-- Third Row: Current Monthly Progress Text -->
        <TextView
            android:id="@+id/monthlyProgressText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:text="Current Month Progress"
            android:textColor="#666666"
            android:textSize="16sp" />

    </LinearLayout>

    <!-- Scrollable Content Area -->
    <ScrollView
        android:id="@+id/contentScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topHeaderRow"
        app:layout_constraintBottom_toTopOf="@id/footerPanel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Available to Spend Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/availableSpendCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="8dp"
                android:elevation="4dp"
                app:cardBackgroundColor="#E8F5E9"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="6dp">

                    <!-- Row for Cash Icon and Label -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical|start">

                        <!-- Cash2 Icon before label -->
                        <ImageView
                            android:id="@+id/cash2Icon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/cash2"
                            android:scaleType="fitCenter"
                            android:contentDescription="Cash Icon"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp" />

                        <!-- Label at Top Middle -->
                        <TextView
                            android:id="@+id/availableSpendLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Extra Available to Spend (Rs)"
                            android:textColor="#2E7D32"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Row for Amount and Cash1 Icon on same line -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="2dp">

                        <!-- Amount Display Space -->
                        <TextView
                            android:id="@+id/availableSpendAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="0"
                            android:textColor="#1B5E20"
                            android:textSize="32sp"
                            android:textStyle="bold" />

                        <!-- Spacer to push cash1 to right -->
                        <Space
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <!-- Cash1 Icon on Right -->
                        <ImageView
                            android:id="@+id/cash1Icon"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/cash1"
                            android:scaleType="fitCenter"
                            android:contentDescription="Cash Icon Bottom"
                            android:layout_marginEnd="8dp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Row Container for Total Income and Total Expenses Cards -->
            <LinearLayout
                android:id="@+id/incomeExpensesRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:gravity="center">

                <!-- Total Income Card (Left Column) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/totalIncomeCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:elevation="4dp"
                    app:cardBackgroundColor="#E3F2FD"
                    app:cardCornerRadius="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="6dp">

                        <!-- Row for Wallet Icon and Label -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical|start">

                            <!-- Wallet2 Icon before label -->

                            <!-- Label at Top Middle -->
                            <TextView
                                android:id="@+id/totalIncomeLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Income (Rs)"
                                android:textColor="#1565C0"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <!-- Row for Amount and Wallet1 Icon on same line -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="2dp">

                            <!-- Amount Display Space -->
                            <TextView
                                android:id="@+id/totalIncomeAmount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="0"
                                android:textColor="#0D47A1"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <!-- Spacer to push wallet1 to right -->
                            <Space
                                android:layout_width="0dp"
                                android:layout_height="1dp"
                                android:layout_weight="1" />

                            <!-- Wallet1 Icon on Right -->
                            <ImageView
                                android:id="@+id/wallet1Icon"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/wallet1"
                                android:scaleType="fitCenter"
                                android:contentDescription="Wallet Icon"
                                android:layout_marginEnd="8dp" />

                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- Total Expenses Card (Right Column) -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/totalExpensesCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:elevation="4dp"
                    app:cardBackgroundColor="#FFEBEE"
                    app:cardCornerRadius="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="6dp">

                        <!-- Row for Label only (no icon before) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical|start">

                            <!-- Label at Top Left -->
                            <TextView
                                android:id="@+id/totalExpensesLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="Total Expenses (Rs)"
                                android:textColor="#C62828"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <!-- Row for Amount and Wallet3 Icon on same line -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="2dp">

                            <!-- Amount Display Space -->
                            <TextView
                                android:id="@+id/totalExpensesAmount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="0"
                                android:textColor="#B71C1C"
                                android:textSize="24sp"
                                android:textStyle="bold" />

                            <!-- Spacer to push wallet3 to right -->
                            <Space
                                android:layout_width="0dp"
                                android:layout_height="1dp"
                                android:layout_weight="1" />

                            <!-- Wallet3 Icon on Right -->
                            <ImageView
                                android:id="@+id/wallet3Icon"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/wallet3"
                                android:scaleType="fitCenter"
                                android:contentDescription="Wallet Icon"
                                android:layout_marginEnd="8dp" />

                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- Target Savings Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/targetSavingsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:elevation="4dp"
                app:cardBackgroundColor="#FFF3E0"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="6dp">

                    <!-- Row for Wallet Icon and Label -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical|start">

                        <!-- Wallet4 Icon before label -->
                        <ImageView
                            android:id="@+id/wallet4Icon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/wallet4"
                            android:scaleType="fitCenter"
                            android:contentDescription="Wallet Icon"
                            android:layout_marginStart="8dp"
                            android:layout_marginEnd="8dp" />

                        <!-- Label at Top Left -->
                        <TextView
                            android:id="@+id/targetSavingsLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Target Savings (Rs)"
                            android:textColor="#E65100"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Row for Amount and Wallet4 Icon on Right on same line -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="2dp">

                        <!-- Amount Display Space -->
                        <TextView
                            android:id="@+id/targetSavingsAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="0"
                            android:textColor="#BF360C"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <!-- Spacer to push icon to right -->
                        <Space
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <!-- Wallet4 Icon on Right -->
                        <ImageView
                            android:id="@+id/targetSavingsIconRight"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/wallet4"
                            android:scaleType="fitCenter"
                            android:contentDescription="Wallet Icon"
                            android:layout_marginEnd="8dp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

    <!-- Footer UI Panel fixed at bottom -->
    <LinearLayout
        android:id="@+id/footerPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@android:color/white"
        android:elevation="8dp"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Menu Item 1: Manage Income -->
        <LinearLayout
            android:id="@+id/menuItemManageIncome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="8dp">

            <ImageView
                android:id="@+id/iconManageIncome"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/manageincome"
                android:scaleType="fitCenter"
                android:contentDescription="Manage Income"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/labelManageIncome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage\nIncome"
                android:textSize="12sp"
                android:textColor="#333333"
                android:textAlignment="center"
                android:lines="2" />

        </LinearLayout>

        <!-- Menu Item 2: Manage Expenses -->
        <LinearLayout
            android:id="@+id/menuItemManageExpenses"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="8dp">

            <ImageView
                android:id="@+id/iconManageExpenses"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/manageexpenses"
                android:scaleType="fitCenter"
                android:contentDescription="Manage Expenses"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/labelManageExpenses"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage\nExpenses"
                android:textSize="12sp"
                android:textColor="#333333"
                android:textAlignment="center"
                android:lines="2" />

        </LinearLayout>

        <!-- Menu Item 3: Manage Target -->
        <LinearLayout
            android:id="@+id/menuItemManageTarget"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="8dp">

            <ImageView
                android:id="@+id/iconManageTarget"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/managetargets"
                android:scaleType="fitCenter"
                android:contentDescription="Manage Target"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/labelManageTarget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage\nTarget"
                android:textSize="12sp"
                android:textColor="#333333"
                android:textAlignment="center"
                android:lines="2" />

        </LinearLayout>

        <!-- Menu Item 4: View Analysis -->
        <LinearLayout
            android:id="@+id/menuItemViewAnalysis"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="8dp">

            <ImageView
                android:id="@+id/iconViewAnalysis"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/viewanalysis"
                android:scaleType="fitCenter"
                android:contentDescription="View Analysis"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/labelViewAnalysis"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View\nAnalysis"
                android:textSize="12sp"
                android:textColor="#333333"
                android:textAlignment="center"
                android:lines="2" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>