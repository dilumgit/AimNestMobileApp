<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".UpgradePro">

    <!-- Top Logo -->
    <ImageView
        android:id="@+id/topLogo"
        android:layout_width="110dp"
        android:layout_height="90dp"
        android:src="@drawable/aimnestlogo2"
        android:scaleType="fitCenter"
        android:contentDescription="AimNest Logo"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/headerSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/topLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/backButton"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/back"
            android:scaleType="fitCenter"
            android:contentDescription="Back" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/upgradeTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upgrade to Pro"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#0B0F3F" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- Subtitle -->
    <TextView
        android:id="@+id/subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Unlock smart insights and advanced analysis"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/headerSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scrollable Content -->
    <ScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/subtitle"
        app:layout_constraintBottom_toTopOf="@id/securityRow"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- Pro Plan Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/proPlanCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#E0E0E0"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Pro"
                        android:textColor="#333333"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="Rs. 960/month"
                        android:textColor="#333333"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:text="Cancel anytime"
                        android:textColor="#999999"
                        android:textSize="13sp" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#F5F5F5"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <!-- Feature 1 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="10dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_marginEnd="12dp"
                                    android:contentDescription="Feature Icon"
                                    android:scaleType="fitCenter"
                                    android:src="@drawable/pro1" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Smart financial suggestions"
                                    android:textColor="#666666"
                                    android:textSize="14sp" />

                            </LinearLayout>

                            <!-- Feature 2 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="10dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_marginEnd="12dp"
                                    android:contentDescription="Feature Icon"
                                    android:scaleType="fitCenter"
                                    android:src="@drawable/pro2" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Target completion forecast"
                                    android:textColor="#666666"
                                    android:textSize="14sp" />

                            </LinearLayout>

                            <!-- Feature 3 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="10dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_marginEnd="12dp"
                                    android:contentDescription="Feature Icon"
                                    android:scaleType="fitCenter"
                                    android:src="@drawable/pro3" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Advanced analytics &amp; insights"
                                    android:textColor="#666666"
                                    android:textSize="14sp" />

                            </LinearLayout>

                            <!-- Feature 4 -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_marginEnd="12dp"
                                    android:contentDescription="Feature Icon"
                                    android:scaleType="fitCenter"
                                    android:src="@drawable/pro4" />

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Smart financial suggestions"
                                    android:textColor="#666666"
                                    android:textSize="14sp" />

                            </LinearLayout>

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Payment Method Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/paymentMethodCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@android:color/white"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Payment method"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="16dp" />

                    <!-- VISA Option -->
                    <LinearLayout
                        android:id="@+id/visaContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="12dp">

                        <!-- VISA Card Header -->
                        <LinearLayout
                            android:id="@+id/visaHeader"
                            android:layout_width="match_parent"
                            android:layout_height="60dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="12dp"
                            android:background="@drawable/payment_card_background">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="24dp"
                                android:src="@drawable/visa"
                                android:scaleType="fitCenter"
                                android:layout_marginEnd="12dp"
                                android:contentDescription="VISA" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="VISA"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="#333333" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="•••• 1234"
                                    android:textSize="12sp"
                                    android:textColor="#666666" />

                            </LinearLayout>

                            <RadioButton
                                android:id="@+id/visaRadio"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp" />

                        </LinearLayout>

                        <!-- VISA Details Form (Initially Hidden) -->
                        <LinearLayout
                            android:id="@+id/visaDetailsContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp"
                            android:background="@drawable/payment_card_background"
                            android:visibility="gone">

                            <!-- Cardholder Name -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Cardholder Name"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#333333"
                                android:layout_marginBottom="4dp" />

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/cardholderNameInput"
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:hint="Enter cardholder name"
                                android:inputType="text"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:background="@android:color/white"
                                android:layout_marginBottom="12dp" />

                            <!-- Card Number -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Card Number"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#333333"
                                android:layout_marginBottom="4dp" />

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/cardNumberInput"
                                android:layout_width="match_parent"
                                android:layout_height="40dp"
                                android:hint="1234 5678 9012 3456"
                                android:inputType="number"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:background="@android:color/white"
                                android:layout_marginBottom="12dp" />

                            <!-- Expiry and CVV Row -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <!-- Expiry Date -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:layout_marginEnd="8dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Expiry Date"
                                        android:textSize="12sp"
                                        android:textStyle="bold"
                                        android:textColor="#333333"
                                        android:layout_marginBottom="4dp" />

                                    <com.google.android.material.textfield.TextInputEditText
                                        android:id="@+id/expiryDateInput"
                                        android:layout_width="match_parent"
                                        android:layout_height="40dp"
                                        android:hint="MM/YY"
                                        android:inputType="number"
                                        android:paddingStart="12dp"
                                        android:paddingEnd="12dp"
                                        android:background="@android:color/white" />

                                </LinearLayout>

                                <!-- CVV -->
                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:layout_marginStart="8dp">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="CVV"
                                        android:textSize="12sp"
                                        android:textStyle="bold"
                                        android:textColor="#333333"
                                        android:layout_marginBottom="4dp" />

                                    <com.google.android.material.textfield.TextInputEditText
                                        android:id="@+id/cvvInput"
                                        android:layout_width="match_parent"
                                        android:layout_height="40dp"
                                        android:hint="123"
                                        android:inputType="number"
                                        android:paddingStart="12dp"
                                        android:paddingEnd="12dp"
                                        android:background="@android:color/white" />

                                </LinearLayout>

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Mastercard Option -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="@drawable/payment_card_background"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="24dp"
                            android:src="@drawable/wallet1"
                            android:scaleType="fitCenter"
                            android:layout_marginEnd="12dp"
                            android:contentDescription="Mastercard" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mastercard"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#333333" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="•••• 8891"
                                android:textSize="12sp"
                                android:textColor="#666666" />

                        </LinearLayout>

                        <RadioButton
                            android:id="@+id/mastercardRadio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp" />

                    </LinearLayout>

                    <!-- Google Pay Option -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="@drawable/payment_card_background"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="24dp"
                            android:src="@drawable/pro1"
                            android:scaleType="fitCenter"
                            android:layout_marginEnd="12dp"
                            android:contentDescription="Google Pay" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Google Pay"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#333333" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Saved account"
                                android:textSize="12sp"
                                android:textColor="#666666" />

                        </LinearLayout>

                        <RadioButton
                            android:id="@+id/googlePayRadio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp" />

                    </LinearLayout>

                    <!-- Bank Transfer Option -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="@drawable/payment_card_background"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="24dp"
                            android:src="@drawable/pro2"
                            android:scaleType="fitCenter"
                            android:layout_marginEnd="12dp"
                            android:contentDescription="Bank Transfer" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bank Transfer"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#333333" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Direct transfer"
                                android:textSize="12sp"
                                android:textColor="#666666" />

                        </LinearLayout>

                        <RadioButton
                            android:id="@+id/bankTransferRadio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp" />

                    </LinearLayout>

                    <!-- Apple Pay Option -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="@drawable/payment_card_background">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="24dp"
                            android:src="@drawable/pro3"
                            android:scaleType="fitCenter"
                            android:layout_marginEnd="12dp"
                            android:contentDescription="Apple Pay" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Apple Pay"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#333333" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Quick payment"
                                android:textSize="12sp"
                                android:textColor="#666666" />

                        </LinearLayout>

                        <RadioButton
                            android:id="@+id/applePayRadio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp" />

                    </LinearLayout>


                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Continue to Payment Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/continuePaymentButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Continue to Payment"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="16sp"
                app:backgroundTint="#1976D2"
                app:cornerRadius="12dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginBottom="12dp" />

            <!-- Maybe Later Text Button -->
            <TextView
                android:id="@+id/maybeLaterButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Maybe later"
                android:textSize="14sp"
                android:textColor="#1976D2"
                android:textStyle="bold"
                android:padding="8dp"
                android:layout_gravity="center_horizontal" />

        </LinearLayout>

    </ScrollView>

    <!-- Security Information Row -->
    <LinearLayout
        android:id="@+id/securityRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/lock"
            android:scaleType="fitCenter"
            android:contentDescription="Security"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Secure payment . No ads . No data sharing"
            android:textSize="13sp"
            android:textColor="#999999" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

