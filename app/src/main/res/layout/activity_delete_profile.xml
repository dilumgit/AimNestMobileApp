<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80000000"
    tools:context=".DeleteProfileActivity">

    <!-- Centered Delete Confirmation Dialog -->
    <androidx.cardview.widget.CardView
        android:id="@+id/confirmationDialog"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="@android:color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- Warning Icon (Red Triangle with Exclamation) -->
            <TextView
                android:id="@+id/warningIcon"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:text="⚠️"
                android:textSize="64sp"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <!-- Title Text -->
            <TextView
                android:id="@+id/dialogTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Are you sure you want to delete your profile?"
                android:textSize="18sp"
                android:textColor="#212121"
                android:textStyle="bold"
                android:textAlignment="center"
                android:layout_marginBottom="12dp" />

            <!-- Subtitle Text -->
            <TextView
                android:id="@+id/dialogSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All your data will be permanently removed and cannot be recovered."
                android:textSize="14sp"
                android:textColor="#757575"
                android:textAlignment="center"
                android:layout_marginBottom="24dp" />

            <!-- Delete Profile Button (Red) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/dialogDeleteButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Delete Profile"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#D32F2F"
                app:cornerRadius="12dp"
                android:paddingVertical="14dp"
                android:layout_marginBottom="12dp" />

            <!-- Cancel Button (Light Gray) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/dialogCancelButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cancel"
                android:textColor="#424242"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#E0E0E0"
                app:cornerRadius="12dp"
                android:paddingVertical="14dp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>