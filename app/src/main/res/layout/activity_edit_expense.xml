<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".EditExpenseActivity">

    <!-- Top Logo -->
    <ImageView
        android:id="@+id/topLogo"
        android:layout_width="110dp"
        android:layout_height="90dp"
        android:src="@drawable/aimnestlogo2"
        android:scaleType="fitCenter"
        android:contentDescription="AimNest Logo"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Title Row with Back Button -->
    <LinearLayout
        android:id="@+id/titleRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="16dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintTop_toBottomOf="@id/topLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Back Button Icon on Left -->
        <ImageView
            android:id="@+id/backButton"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/back"
            android:scaleType="fitCenter"
            android:contentDescription="Back" />

        <!-- Spacer to push title to center -->
        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Edit Expense Title (Centered) -->
        <TextView
            android:id="@+id/editExpenseTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edit Expense"
            android:textSize="20sp"
            android:textColor="#0B0F3F"
            android:textStyle="bold" />

        <!-- Spacer to balance the layout -->
        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

    </LinearLayout>

    <!-- Form Container CardView -->
    <androidx.cardview.widget.CardView
        android:id="@+id/formCardView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        android:backgroundTint="#C9D9F0"
        android:layout_margin="16dp"
        app:layout_constraintTop_toBottomOf="@id/titleRow"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Expense Name Field -->
            <TextView
                android:id="@+id/expenseNameLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Expense Name"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/expenseNameInput"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/rounded_input_background"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="Rent"
                android:textSize="13sp"
                android:layout_marginBottom="12dp"
                android:inputType="text" />

            <!-- Amount Field -->
            <TextView
                android:id="@+id/amountLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Amount"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/amountInput"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/rounded_input_background"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="Rs 15,000"
                android:textSize="13sp"
                android:layout_marginBottom="12dp"
                android:inputType="numberDecimal" />

            <!-- Category Field -->
            <TextView
                android:id="@+id/categoryLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:background="@drawable/rounded_input_background"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="12dp">

                <Spinner
                    android:id="@+id/categorySpinner"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:spinnerMode="dropdown" />

            </LinearLayout>

            <!-- Mandatory Toggle Field -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/mandatoryLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Mandatory"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#333333" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/mandatorySwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:switchPadding="6dp" />

            </LinearLayout>

            <!-- Expense Date Field -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:background="@drawable/rounded_input_background"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Expense Date"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/dateInputText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="04/01/2026"
                    android:textSize="13sp"
                    android:textColor="#333333"
                    android:gravity="center" />

                <ImageView
                    android:id="@+id/calendarIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/calendar"
                    android:contentDescription="Calendar"
                    android:scaleType="fitCenter" />

            </LinearLayout>

            <!-- Buttons Container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:spacing="8dp">

                <!-- Update Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/updateExpenseButton"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Update Expense"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    app:backgroundTint="#1976D2"
                    app:cornerRadius="10dp"
                    android:layout_marginBottom="8dp" />

                <!-- Cancel Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/cancelButton"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="Cancel"
                    android:textColor="#555555"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    app:backgroundTint="#F2F2F2"
                    app:cornerRadius="10dp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>