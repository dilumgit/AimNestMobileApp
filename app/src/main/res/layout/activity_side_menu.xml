<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SideMenuActivity">

    <!-- Clickable overlay for the right side (white space) -->
    <View
        android:id="@+id/overlayView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:clickable="true"
        android:focusable="true" />

    <!-- Side Menu Panel -->
    <LinearLayout
        android:id="@+id/main"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:background="#E3F2FD"
        android:clickable="true"
        android:focusable="true"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="horizontal"
            android:paddingTop="32dp"
            android:paddingBottom="24dp">

            <ImageView
                android:id="@+id/sideMenuLogo"
                android:layout_width="100dp"
                android:layout_height="80dp"
                android:contentDescription="@string/app_name"
                android:scaleType="fitCenter"
                android:src="@drawable/aimnestlogo2" />
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">

                <!-- Menu Item 1: Alerts & Warnings -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="28dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/alertsIcon"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:contentDescription="@string/app_name"
                        android:scaleType="fitCenter"
                        android:src="@drawable/alerts" />

                    <TextView
                        android:id="@+id/alertsText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Alerts &amp; Warnings"
                        android:textColor="#0B0F3F"
                        android:textSize="17sp" />
                </LinearLayout>

                <!-- Menu Item 2: Notification Center -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="28dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/notificationsIcon"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:contentDescription="@string/app_name"
                        android:scaleType="fitCenter"
                        android:src="@drawable/notifications" />

                    <TextView
                        android:id="@+id/notificationsText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Notification Center"
                        android:textColor="#0B0F3F"
                        android:textSize="17sp" />
                </LinearLayout>

                <!-- Menu Item 3: Targets Overview -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="28dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/targetsIcon"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:contentDescription="@string/app_name"
                        android:scaleType="fitCenter"
                        android:src="@drawable/targetoverview" />

                    <TextView
                        android:id="@+id/targetsText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Targets Overview"
                        android:textColor="#0B0F3F"
                        android:textSize="17sp" />
                </LinearLayout>

                <!-- Menu Item 4: Smart Suggestions -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="28dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/suggestionsIcon"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:contentDescription="@string/app_name"
                        android:scaleType="fitCenter"
                        android:src="@drawable/smartsuggetions" />

                    <TextView
                        android:id="@+id/suggestionsText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Smart Suggestions"
                        android:textColor="#0B0F3F"
                        android:textSize="17sp" />
                </LinearLayout>

                <!-- Menu Item 5: Monthly Income Summary -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="28dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/incomeIcon"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:contentDescription="@string/app_name"
                        android:scaleType="fitCenter"
                        android:src="@drawable/monthlyincomesummary" />

                    <TextView
                        android:id="@+id/incomeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Monthly Income Summary"
                        android:textColor="#0B0F3F"
                        android:textSize="17sp" />
                </LinearLayout>

                <!-- Menu Item 6: Overall Analysis -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="28dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/analysisIcon"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:contentDescription="@string/app_name"
                        android:scaleType="fitCenter"
                        android:src="@drawable/overallanylisis" />

                    <TextView
                        android:id="@+id/analysisText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Overall Analysis"
                        android:textColor="#0B0F3F"
                        android:textSize="17sp" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</FrameLayout>
